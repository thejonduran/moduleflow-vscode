{
  "name": "moduleflow-vscode",
  "displayName": "ModuleFlow",
  "description": "A visual module orchestrator for composing JavaScript exports directly into an editable JavaScript file.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejonduran/moduleflow-vscode.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:moduleflow.openFile","onCommand:moduleflow.importTools","onCommand:moduleflow.refresh"],
  "main": "./out/extension.js",
  "contributes": {"commands":[{"command":"moduleflow.openFile","title":"ModuleFlow: Open Current File"},{"command":"moduleflow.importTools","title":"ModuleFlow: Import Tools"},{"command":"moduleflow.refresh","title":"ModuleFlow: Refresh Current File"}],"menus":{"explorer/context":[{"command":"moduleflow.openFile","when":"resourceExtname == .js","group":"navigation"}],"editor/context":[{"command":"moduleflow.openFile","when":"resourceExtname == .js","group":"navigation"}]},"configuration":{"title":"ModuleFlow","properties":{"moduleflow.generatedFunctionName":{"type":"string","default":"main","description":"Default exported function name used when ModuleFlow creates a new composition region."}}}},"scripts":{"compile":"npm run build:webview && tsc -p ./","build:webview":"node scripts/build-webview.js","preview:webview":"npm run build:webview && node scripts/preview-webview.js","preview:webview:serve":"npm run preview:webview && node scripts/serve-preview-webview.js","watch":"tsc -watch -p ./","test:roundtrip":"node scripts/test-roundtrip.js","test":"npm run build:webview && tsc -p ./ && node scripts/test-roundtrip.js"},"dependencies":{"@babel/generator":"^7.24.10","@babel/parser":"^7.24.8","@babel/types":"^7.24.9","@codemirror/autocomplete":"^6.20.3","@codemirror/commands":"^6.10.4","@codemirror/lang-javascript":"^6.2.5","@codemirror/language":"^6.12.4","@codemirror/state":"^6.7.0","@codemirror/view":"^6.43.5","@lezer/highlight":"^1.2.3","@xyflow/react":"^12.3.5","react":"^18.3.1","react-dom":"^18.3.1"},"devDependencies":{"@types/babel__generator":"^7.27.0","@types/node":"^20.14.10","@types/react":"^18.3.3","@types/react-dom":"^18.3.0","@types/vscode":"^1.92.0","esbuild":"^0.23.0","typescript":"^5.5.3"}}
